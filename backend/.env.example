# ── App ───────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true

# ── Database ──────────────────────────────────────────
# Both postgres:// and postgresql:// schemes are accepted.
DATABASE_URL=postgresql://vyre:vyre_secret@localhost:5432/vyre

# ── Redis ─────────────────────────────────────────────
# Currently unused (workers disabled on free tier).
REDIS_URL=redis://localhost:6379/0

# ── Auth ──────────────────────────────────────────────
JWT_SECRET=change_this_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ── Anthropic ─────────────────────────────────────────
# Without a real key the app boots and most routes work; only
# /diagnostics/{id}/submit will fail when it tries to call Claude.
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514
AI_PROMPT_VERSION=v1.0

# ── AWS S3 ────────────────────────────────────────────
# Leave empty to use the local filesystem at /tmp/vyre_files.
# Storage auto-detects empty keys and falls back to local.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=vyre-files
AWS_REGION=eu-west-2

# ── Storage override ──────────────────────────────────
# Force local storage even if AWS keys are set:
# USE_LOCAL_STORAGE=true
# LOCAL_STORAGE_PATH=/tmp/vyre_files

# ── CORS ──────────────────────────────────────────────
# JSON-encoded list of allowed origins.
CORS_ORIGINS=["http://localhost:3000"]

# ── Reference prefix (for diagnostic IDs like RVL-2026-0001) ──
DIAGNOSTIC_REF_PREFIX=RVL
