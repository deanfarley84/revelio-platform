# ============================================================
# VYRE — Environment Configuration
# Copy to .env and fill in your values before running
# ============================================================

# App
ENVIRONMENT=development
DEBUG=true

# Database
POSTGRES_PASSWORD=vyre_secret_change_me
DATABASE_URL=postgresql://vyre:vyre_secret_change_me@localhost:5432/vyre

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth — generate with: openssl rand -hex 32
JWT_SECRET=change_this_to_a_random_64_char_secret

# Anthropic (required) — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# AWS S3 — create bucket with IAM read/write access
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_S3_BUCKET=vyre-files
AWS_REGION=eu-west-2

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXTAUTH_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Seed (used by scripts/setup.py)
ADMIN_EMAIL=admin@vyre.io
ADMIN_PASSWORD=Admin1234!
ADMIN_NAME=Operator Admin
